# Copy this file to ".env" and fill in your own values.

# The port our Express server will run on
PORT=5000

# The MongoDB connection string for our normal database
MONGO_URI=mongodb://127.0.0.1:27017/greenwheels

# The MongoDB connection string used ONLY when running automated tests
# (this keeps test data separate from your real data)
MONGO_URI_TEST=mongodb://127.0.0.1:27017/greenwheels_test
